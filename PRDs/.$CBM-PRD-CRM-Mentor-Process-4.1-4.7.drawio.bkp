        </mxCell>
        <!-- Step 7: Involvement concludes -->
        <mxCell id="sme_7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;" value="When SME involvement concludes:&#xa;Admin removes SME link from Engagement&#xa;→ scoped access revoked" vertex="1">

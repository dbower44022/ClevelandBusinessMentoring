          <mxGeometry height="20" width="120" x="55" y="153" as="geometry" />
        </mxCell>
        <!-- Header -->
        <mxCell id="sme_hdr" parent="1" style="shape=mxgraph.flowchart.start_2;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a237e;fontColor=#FFFFFF;strokeColor=#1a237e;rounded=1;arcSize=20;size=0.09;" value="4.4 — SME Request Workflow" vertex="1">
          <mxGeometry height="50" width="400" x="200" y="30" as="geometry" />
        </mxCell>
        <!-- Step 1 -->
        <mxCell id="sme_1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;" value="Primary Mentor initiates SME Request&#xa;from Engagement record&#xa;(identifies expertise needed)" vertex="1">
